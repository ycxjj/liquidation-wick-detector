# Flask
FLASK_SECRET_KEY=change-me-to-random-string

# 测试登录（无需钱包）；生产对外上线建议 0
ENABLE_TEST_LOGIN=1

# Gunicorn（2GB VPS 建议 workers=1 或 2，勿用 4）
# GUNICORN_WORKERS=2
# GUNICORN_THREADS=2
ADMIN_PATH=admin
ADMIN_ADDRESSES=0xYourAdminWallet1,0xYourAdminWallet2

# Redis 限流（可选；不设置则使用内存限流，与改前行为一致）
# REDIS_URL=redis://127.0.0.1:6379/0

# 提币地址修改冷却期（小时）
WITHDRAWAL_COOLDOWN_HOURS=72

# 每日日报调度（可选）
# DISABLE_DAILY_SCHEDULER=1
# DAILY_CRON_HOUR=8
# DAILY_CRON_MINUTE=0
# 默认采集 1m K 线、交易所全市场可用合约；页面只展示前 100
# DAILY_TIMEFRAME=1m
# DAILY_TOP_N=0
# DAILY_SCAN_WORKERS=4
# Gate.io 旧 1m 数据不返回时自动降级 5m
# DAILY_GATE_OLD_1M_FALLBACK_5M=1
# 历史补跑（五所 1m + Gate 5m，默认 2026-04-01 ~ 2026-05-09）:
# BACKGROUND=1 bash scripts/backfill_history_gate5m_others1m.sh

# 日报完成后自动 git 提交推送（data/reports + data/wick_daily.db）
# 未推送时: bash scripts/push_daily_reports_git.sh 2026-05-17
# 诊断: python3 scripts/git_auto_commit_check.py
# 日志: tail -20 data/logs/git_auto_commit.log
# DISABLE_GIT_AUTO_PUSH=1
# GIT_AUTHOR_NAME=wickdetector-bot
# GIT_AUTHOR_EMAIL=bot@wickdetector.com
# GIT_PUSH_REMOTE=origin
# GIT_PUSH_BRANCH=main
# GIT_AUTHOR_NAME=wickdetector-bot
# GIT_AUTHOR_EMAIL=bot@wickdetector.com

# --- WickShield 实时监控 v2 / P2 ---
# WICKSHIELD_POOL=100000
# WICKSHIELD_COVERAGE=50000
# WICKSHIELD_MONITOR_DAYS_BACK=0.3
# WICKSHIELD_MONITOR_LIGHT=1
# WICKSHIELD_CLAIM_FULL_VERIFY=1
# WICKSHIELD_CLAIMS_DB=1
# WICKSHIELD_OHLCV_CACHE=1
# WICKSHIELD_OHLCV_CACHE_TTL=90
# WICKSHIELD_WS_ENABLE=1
# WICKSHIELD_REDIS_HOST=127.0.0.1

