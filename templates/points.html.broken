<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>积分系统 - Wick Detector</title>
    <link rel="icon" type="image/png" href="/logo.png">
    <style>
        body { background: #0a0e27; color: #e0e6ed; font-family: sans-serif; margin: 0; padding: 20px; }
        .container { max-width: 1200px; margin: 0 auto; }
        h1 { color: #00d4ff; text-align: center; font-size: 2.5rem; }
        .card { background: #10192e; border: 1px solid #1e3a5f; border-radius: 12px; padding: 30px; margin: 20px 0; }
        .btn { background: #00d4ff; color: #042; padding: 12px 24px; border: none; border-radius: 8px; cursor: pointer; font-size: 16px; font-weight: bold; transition: all 0.2s; }
        .btn:hover { opacity: 0.9; transform: translateY(-1px); }
        .btn-secondary { background: transparent; border: 1px solid #1e3a5f; color: #e0e6ed; }
        .stats { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 20px; margin: 20px 0; }
        .stat { text-align: center; padding: 20px; background: rgba(0,212,255,0.05); border-radius: 10px; border: 1px solid #1e3a5f; }
        .stat-value { font-size: 2rem; color: #00d4ff; font-weight: bold; }
        .stat-label { color: #8892b0; font-size: 0.9rem; margin-top: 5px; }
        .wallet { font-family: monospace; background: rgba(0,0,0,0.3); padding: 8px 12px; border-radius: 6px; word-break: break-all; font-size: 0.9rem; }
        .alert { padding: 12px 20px; border-radius: 8px; margin: 15px 0; }
        .alert-success { background: rgba(62,207,142,0.1); border: 1px solid #3ecf8e; color: #3ecf8e; }
        .alert-error { background: rgba(255,68,68,0.1); border: 1px solid #f44; color: #f44; }
        .alert-info { background: rgba(0,212,255,0.1); border: 1px solid #00d4ff; color: #00d4ff; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { padding: 12px; text-align: left; border-bottom: 1px solid #1e3a5f; }
        th { color: #00d4ff; font-weight: 600; }
        .back-link { color: #00d4ff; text-decoration: none; display: inline-block; margin-bottom: 20px; }
        .login-buttons { display: flex; flex-direction: column; gap: 15px; align-items: center; }
        .wallet-info { background: rgba(0,212,255,0.05); padding: 15px; border-radius: 8px; margin-top: 15px; font-size: 0.9rem; color: #8892b0; }
        .wallet-info a { color: #00d4ff; text-decoration: none; }
        .wallet-info a:hover { text-decoration: underline; }
        
        /* 模态框样式 */
        .modal { display: none; position: fixed; z-index: 1000; left: 0; top: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.8); }
        .modal-content { background: #10192e; margin: 10% auto; padding: 30px; border: 1px solid #1e3a5f; border-radius: 12px; max-width: 500px; }
        .modal-header { color: #00d4ff; font-size: 1.5rem; margin-bottom: 20px; }
        .modal-body { color: #e0e6ed; line-height: 1.8; }
        .modal-footer { margin-top: 20px; text-align: right; }
        .close-btn { background: #1e3a5f; color: #e0e6ed; padding: 8px 20px; border: none; border-radius: 6px; cursor: pointer; }
        .wallet-option { display: flex; align-items: center; padding: 15px; background: rgba(0,212,255,0.05); border-radius: 8px; margin: 10px 0; cursor: pointer; transition: all 0.2s; }
        .wallet-option:hover { background: rgba(0,212,255,0.1); }
        .wallet-icon { width: 40px; height: 40px; margin-right: 15px; }
    </style>
</head>
<body>
    <div class="container">
        <a href="/" class="back-link">← 返回首页</a>
        <h1>🎯 积分系统</h1>
        <p style="text-align:center;color:#8892b0;margin-bottom:30px;">完成任务获取积分，解锁更多权益</p>

        <div id="loginSection" class="card" style="text-align:center;display:none;">
            <h2>连接钱包登录</h2>
            <p style="color:#8892b0;margin:20px 0;">使用 Web3 钱包签名登录，安全且无需注册</p>
            <div class="login-buttons">
                <button class="btn" onclick="connectWallet()" style="min-width:200px;">🦊 连接钱包</button>
                <button class="btn btn-secondary" onclick="testLogin()" style="min-width:200px;">🧪 测试登录（无需钱包）</button>
            </div>
            <div class="wallet-info">
                <p><strong>什么是 Web3 钱包？</strong></p>
                <p>Web3 钱包是您的数字身份，推荐使用：</p>
                <p>
                    • <a href="https://metamask.io/download/" target="_blank">MetaMask</a> (最流行)<br>
                    • <a href="https://www.okx.com/web3" target="_blank">OKX Wallet</a><br>
                    • <a href="https://www.coinbase.com/wallet" target="_blank">Coinbase Wallet</a>
                </p>
                <p style="margin-top:10px;font-size:0.85rem;">💡 如果只是想体验功能，可以直接点击"测试登录"</p>
            </div>
        </div>

        <div id="userSection" style="display:none;">
            <div class="card">
                <h2 style="color:#00d4ff;">我的积分</h2>
                <div style="text-align:center;margin:15px 0;">
                    <a href="/tasks" style="display:inline-block;background:linear-gradient(135deg,#00d4ff,#0066ff);color:#fff;padding:10px 20px;border-radius:8px;text-decoration:none;font-weight:bold;">📋 每日任务</a>
                </div>
                <div id="alertBox"></div>
                <div class="stats">
                    <div class="stat">
                        <div class="stat-value" id="totalPoints">0</div>
                        <div class="stat-label">总积分</div>
                    </div>
                    <div class="stat">
                        <div class="stat-value" id="userLevel">Lv.1</div>
                        <div class="stat-label">当前等级</div>
                    </div>
                    <div class="stat">
                        <div class="stat-value" id="creditScore">100</div>
                        <div class="stat-label">信用分</div>
                    </div>
                </div>
                <p style="color:#8892b0;margin-top:20px;">钱包地址</p>
                <div class="wallet" id="walletAddress"></div>
                <p style="color:#8892b0;margin-top:15px;">等级称号: <span style="color:#00d4ff;font-weight:bold;" id="levelName">入门侦探</span></p>
                <div style="margin-top:20px;">
                    <button class="btn" onclick="dailyCheckin()">每日签到 (+10)</button>
                    <button class="btn btn-secondary" onclick="window.location.href='/points/history'" style="margin-left:10px;">📊 查看历史</button>
                    <button class="btn btn-secondary" onclick="window.location.href='/invite'" style="margin-left:10px;">👥 邀请好友</button>
                    <button class="btn btn-secondary" onclick="logout()" style="margin-left:10px;">登出</button>
                </div>
            </div>

            <div class="card">
                <div style="text-align:center;margin-top:20px;">
                    <a href="/leaderboard" style="display:inline-block;background:#1e3a5f;color:#00d4ff;padding:12px 24px;border-radius:8px;text-decoration:none;font-weight:bold;">🏆 查看排行榜</a>
                    <a href="/shop" style="display:inline-block;background:#1e3a5f;color:#00d4ff;padding:12px 24px;border-radius:8px;text-decoration:none;font-weight:bold;margin-left:10px;">🛒 积分商城</a>
                </div>
                <h2 style="color:#00d4ff;">积分规则</h2>
                <table>
                    <thead><tr><th>行为</th><th>积分</th><th>频率限制</th></tr></thead>
                    <tbody>
                        <tr><td>每日签到</td><td>+10</td><td>1次/天</td></tr>
                        <tr><td>使用自选检测</td><td>+5</td><td>3次/天</td></tr>
                        <tr><td>提交爆仓案例</td><td>+50</td><td>2次/天</td></tr>
                        <tr><td>案例被确认真实</td><td>+100</td><td>不限</td></tr>
                        <tr><td>分享日报到 X</td><td>+30</td><td>1次/天</td></tr>
                        <tr><td>邀请新用户</td><td>+100</td><td>不限</td></tr>
                        <tr><td>反馈有效 Bug</td><td>+200</td><td>不限</td></tr>
                    </tbody>
                </table>
                <div style="margin-top:20px;padding:15px;background:rgba(0,212,255,0.05);border-radius:8px;">
                    <h3 style="color:#00d4ff;margin-bottom:10px;">等级系统</h3>
                    <ul style="color:#8892b0;line-height:2;">
                        <li><strong>Lv.1 入门侦探</strong>: 0-499 积分</li>
                        <li><strong>Lv.2 初级风控师</strong>: 500-1,999 积分</li>
                        <li><strong>Lv.3 高级风控师</strong>: 2,000-9,999 积分</li>
                        <li><strong>Lv.4 创世检测师</strong>: 10,000+ 积分</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- 钱包未安装提示模态框 -->
    <div id="walletModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">🦊 需要安装 Web3 钱包</div>
            <div class="modal-body">
                <p>检测到您还没有安装 Web3 钱包。</p>
                <p style="margin-top:15px;"><strong>推荐钱包：</strong></p>
                <div class="wallet-option" onclick="window.open('https://metamask.io/download/', '_blank')">
                    <div style="width:40px;height:40px;background:#f6851b;border-radius:50%;display:flex;align-items:center;justify-content:center;margin-right:15px;">🦊</div>
                    <div>
                        <div style="font-weight:bold;">MetaMask</div>
                        <div style="font-size:0.85rem;color:#8892b0;">最流行的 Web3 钱包</div>
                    </div>
                </div>
                <div class="wallet-option" onclick="window.open('https://www.okx.com/web3', '_blank')">
                    <div style="width:40px;height:40px;background:#000;border-radius:50%;display:flex;align-items:center;justify-content:center;margin-right:15px;color:#fff;font-weight:bold;">OKX</div>
                    <div>
                        <div style="font-weight:bold;">OKX Wallet</div>
                        <div style="font-size:0.85rem;color:#8892b0;">功能强大的多链钱包</div>
                    </div>
                </div>
                <p style="margin-top:15px;font-size:0.9rem;color:#8892b0;">
                    💡 或者，您可以点击"测试登录"按钮体验功能
                </p>
            </div>
            <div class="modal-footer">
                <button class="close-btn" onclick="closeModal()">知道了</button>
            </div>
        </div>
    </div>

    <script>
        console.log('积分系统页面已加载');
        let currentUser = null;

        async function checkLoginStatus() {
            try {
                const res = await fetch('/api/points/user');
                if (res.ok) {
                    currentUser = await res.json();
                    showUserSection();
                    updateUserInfo();
                } else {
                    showLoginSection();
                }
            } catch (err) {
                console.error('检查登录状态失败:', err);
                showLoginSection();
            }
        }

        function showLoginSection() {
            document.getElementById('loginSection').style.display = 'block';
            document.getElementById('userSection').style.display = 'none';
        }

        function showUserSection() {
            document.getElementById('loginSection').style.display = 'none';
            document.getElementById('userSection').style.display = 'block';
        }

        function updateUserInfo() {
            if (!currentUser) return;
            document.getElementById('totalPoints').textContent = currentUser.total_points;
            document.getElementById('userLevel').textContent = 'Lv.' + currentUser.level;
            document.getElementById('creditScore').textContent = currentUser.credit_score;
            document.getElementById('walletAddress').textContent = currentUser.wallet_address;
            document.getElementById('levelName').textContent = currentUser.level_info.name;
        }

        function closeModal() {
            document.getElementById('walletModal').style.display = 'none';
        }

        async function connectWallet() {
            // 检查是否安装了钱包
            if (typeof window.ethereum === 'undefined') {
                // 显示提示模态框
                document.getElementById('walletModal').style.display = 'block';
                return;
            }

            try {
                const accounts = await window.ethereum.request({ method: 'eth_requestAccounts' });
                const walletAddress = accounts[0];

                showAlert('正在生成签名消息...', 'info');

                const nonceRes = await fetch('/api/points/nonce', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ wallet_address: walletAddress })
                });
                const { nonce } = await nonceRes.json();

                const signature = await window.ethereum.request({
                    method: 'personal_sign',
                    params: [nonce, walletAddress]
                });

                const loginRes = await fetch('/api/points/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ wallet_address: walletAddress, signature, nonce })
                });

                if (loginRes.ok) {
                    const data = await loginRes.json();
                    currentUser = data.user;
                    showUserSection();
                    updateUserInfo();
                    showAlert('登录成功！', 'success');
                } else {
                    const error = await loginRes.json();
                    showAlert(error.error || '登录失败', 'error');
                }
            } catch (err) {
                console.error('连接钱包失败:', err);
                if (err.code === 4001) {
                    showAlert('您取消了连接请求', 'error');
                } else {
                    showAlert('连接钱包失败: ' + err.message, 'error');
                }
            }
        }

        async function testLogin() {
            const testWallet = '0x' + Math.random().toString(16).substr(2, 40);
            try {
                showAlert('正在创建测试账号...', 'info');
                
                const nonceRes = await fetch('/api/points/nonce', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ wallet_address: testWallet })
                });
                const { nonce } = await nonceRes.json();

                const loginRes = await fetch('/api/points/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ wallet_address: testWallet, signature: 'test', nonce })
                });

                if (loginRes.ok) {
                    const data = await loginRes.json();
                    currentUser = data.user;
                    showUserSection();
                    updateUserInfo();
                    showAlert('测试登录成功！', 'success');
                }
            } catch (err) {
                showAlert('测试登录失败: ' + err.message, 'error');
            }
        }

        async function dailyCheckin() {
            try {
                const res = await fetch('/api/points/checkin', { method: 'POST' });
                const data = await res.json();
                
                if (data.success) {
                    showAlert(data.message, 'success');
                    currentUser.total_points = data.total_points;
                    updateUserInfo();
                    // 更新签到按钮状态
                    await updateCheckinButton();
                } else {
                    showAlert(data.message, 'error');
                    // 即使失败也更新按钮状态（可能已经签到过了）
                    await updateCheckinButton();
                }
            } catch (err) {
                showAlert('签到失败', 'error');
            }
        }

        async function logout() {
            await fetch('/api/points/logout', { method: 'POST' });
            currentUser = null;
            showLoginSection();
            showAlert('已登出', 'info');
        }

        function showAlert(message, type) {
            const alertBox = document.getElementById('alertBox');
            alertBox.innerHTML = '<div class="alert alert-' + type + '">' + message + '</div>';
            setTimeout(function() { alertBox.innerHTML = ''; }, 5000);
        }

        // 点击模态框外部关闭
        window.onclick = function(event) {
            const modal = document.getElementById('walletModal');
            if (event.target == modal) {
                closeModal();
            }
        }

        checkLoginStatus();
    </script>

<script>
(function () {
  async function doTestLogin() {
    const btns = Array.from(document.querySelectorAll('button, a'));
    const testBtns = btns.filter(el => (el.textContent || '').includes('测试登录') || (el.textContent || '').includes('无需钱包'));
    testBtns.forEach(el => {
      el.disabled = true;
      el.dataset.oldText = el.textContent;
      el.textContent = '登录中...';
    });

    try {
      const res = await fetch('/api/points/test_login', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({})
      });
      const data = await res.json();

      if (!res.ok || !data.success) {
        throw new Error(data.error || data.message || '测试登录失败');
      }

      window.location.reload();
    } catch (err) {
      alert(err.message || '测试登录失败');
      testBtns.forEach(el => {
        el.disabled = false;
        el.textContent = el.dataset.oldText || '测试登录（无需钱包）';
      });
    }
  }

  window.testLogin = doTestLogin;
  window.testWalletLogin = doTestLogin;

  document.addEventListener('click', function (e) {
    const el = e.target.closest('button, a');
    if (!el) return;

    const text = el.textContent || '';
    if (text.includes('测试登录') || text.includes('无需钱包')) {
      e.preventDefault();
      doTestLogin();
    }
  });
})();
</script>

</body>
</html>
