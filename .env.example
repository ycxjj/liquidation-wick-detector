# Flask
FLASK_SECRET_KEY=change-me-to-random-string
ADMIN_PATH=admin
ADMIN_ADDRESSES=0xYourAdminWallet1,0xYourAdminWallet2

# Redis 限流（可选；不设置则使用内存限流，与改前行为一致）
# REDIS_URL=redis://127.0.0.1:6379/0

# 提币地址修改冷却期（小时）
WITHDRAWAL_COOLDOWN_HOURS=72

# 每日日报调度（可选）
# DISABLE_DAILY_SCHEDULER=1
# DAILY_CRON_HOUR=8
# DAILY_CRON_MINUTE=0

# 日报完成后自动 git 提交推送（data/reports + data/wick_daily.db）
# DISABLE_GIT_AUTO_PUSH=1
# GIT_PUSH_REMOTE=origin
# GIT_PUSH_BRANCH=main
# GIT_AUTHOR_NAME=wickdetector-bot
# GIT_AUTHOR_EMAIL=bot@wickdetector.com
